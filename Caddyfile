paperpilotapp.com, www.paperpilotapp.com {
	handle /api/* {
		reverse_proxy backend:8000
	}

	handle /ws {
		reverse_proxy backend:8000
	}

	handle /docs {
		reverse_proxy backend:8000
	}

	handle /openapi.json {
		reverse_proxy backend:8000
	}

	handle {
		reverse_proxy frontend:3000
	}
}

thinktradehub.com, www.thinktradehub.com {
	handle /api/* {
		reverse_proxy host.docker.internal:8011
	}

	handle /auth/* {
		reverse_proxy host.docker.internal:8011
	}

	handle /health {
		reverse_proxy host.docker.internal:8011
	}

	handle /ws/* {
		reverse_proxy host.docker.internal:8031
	}

	handle {
		reverse_proxy host.docker.internal:3000
	}
}
