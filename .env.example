
# ============================================================
# DATABASE
# ============================================================
# PostgreSQL connection string (asyncpg driver required)
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql+asyncpg://paperpilot:dev_password@localhost:5432/paperpilot

# ============================================================
# REDIS
# ============================================================
# Redis connection URL used for caching, pub/sub, and session state
# Format: redis://<host>:<port>/<db_index>
REDIS_URL=redis://localhost:6379/0

# ============================================================
# MINIO (Object Storage)
# ============================================================
# MinIO endpoint (host:port) — no http:// prefix
MINIO_ENDPOINT=localhost:9000
# MinIO access key (equivalent to AWS_ACCESS_KEY_ID)
MINIO_ACCESS_KEY=minioadmin
# MinIO secret key (equivalent to AWS_SECRET_ACCESS_KEY)
MINIO_SECRET_KEY=minioadmin
# Set to true when using HTTPS (production)
MINIO_SECURE=false

# ============================================================
# JWT / AUTHENTICATION
# ============================================================
# Secret key for signing JWT tokens — MUST be changed in production
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=dev-jwt-secret-change-in-production-please
# JWT signing algorithm — HS256 is standard; do not change without reason
JWT_ALGORITHM=HS256
# Access token lifetime in minutes (default 1440 = 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440
# Refresh token lifetime in days (default 30 days)
REFRESH_TOKEN_EXPIRE_DAYS=30

# ============================================================
# ENCRYPTION
# ============================================================
# Key used for encrypting sensitive fields at rest.
# MUST be exactly 32 ASCII bytes — the app will refuse to start otherwise.
# Dev placeholder below is exactly 32 bytes (verified).
# Generate a production key: python -c "import secrets; print(secrets.token_hex(16))"
ENCRYPTION_KEY=dev-encryption-key-exactly-32byt

# ============================================================
# ANTHROPIC CLAUDE API
# ============================================================
# Standard Anthropic API key — obtain from https://console.anthropic.com
#
# ⚠️  NOTE: Claude Max (the claude.ai consumer subscription) does NOT
#     include API access.  You MUST use a paid API key from the Anthropic
#     Console, not your claude.ai account.
#
# Models used by tier:
#   deep     → claude-opus-4-20250514      ($5 / $25 per MTok)
#   standard → claude-sonnet-4-20250514    ($3 / $15 per MTok)
#   simple   → claude-haiku-4-5-20251001   ($1 / $5  per MTok)
#
# Leaving this blank disables AI features; the /health/claude endpoint
# will report status "not_configured" instead of an auth error.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ============================================================
# CORS
# ============================================================
# Comma-separated list of allowed origins for CORS.
# In production, restrict to your actual frontend domain(s).
# This setting is read as a JSON array by pydantic-settings, so use
# proper JSON syntax if overriding via environment variable:
#   CORS_ORIGINS='["https://app.example.com"]'
# (The defaults below cover local dev and the production domain.)
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

