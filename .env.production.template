# Quorum Production Environment
# Copy this to .env.production and fill in real values

# PostgreSQL
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# Redis
REDIS_PASSWORD=CHANGE_ME_redis_password_here

# MinIO (S3-compatible storage)
MINIO_ACCESS_KEY=quorum-minio-admin
MINIO_SECRET_KEY=CHANGE_ME_minio_secret_here

# JWT & Encryption (generate with: openssl rand -hex 32)
JWT_SECRET=CHANGE_ME_jwt_secret_here
ENCRYPTION_KEY=CHANGE_ME_encryption_key_here

# Anthropic API Key for Claude agents
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Public URLs (used by frontend to reach backend)
PUBLIC_API_URL=https://paperpilotapp.com
PUBLIC_WS_URL=wss://paperpilotapp.com
